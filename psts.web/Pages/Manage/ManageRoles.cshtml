@page
@model psts.web.Pages.Manage.ManageRolesModel
@{
    ViewData["Title"] = "Role Management - PSTS Solutions";
}

<h2 style="text-align:center; margin-top:1rem;">Role Management</h2>

<div class="profile-grid">

    <!-- -------------------------------------------------- -->
    <!-- SEARCH BOX -->
    <!-- -------------------------------------------------- -->
    <div class="profile-box grid-item">

        <h2>Find User</h2>

        <form method="get">

            <div class="form-group">
                <p>Search by Name:</p>
                <input type="text"
                       name="q"
                       value="@Model.Query"
                       placeholder="First and/or last name..." />
            </div>

            <button type="submit" class="btn-primary">Search</button>

        </form>

    </div>


    <!-- -------------------------------------------------- -->
    <!-- ROLE MANAGEMENT BOX -->
    <!-- -------------------------------------------------- -->
    <div class="password-box grid-item">

        <h2>Assign Role</h2>

        <form method="post">

            <!-- USER LIST -->
            <div class="form-group">
                <p>Select User:</p>

                <select name="SelectedUserId"
                        size="8"
                        style="width:100%; padding:0.625rem; background-color:var(--primary-bg-color); color:white; border:0.0625rem solid var(--border-bg); border-radius:0.25rem;">
                    @if (Model.SearchResults.Count > 0)
                    {
                        @foreach (var user in Model.SearchResults)
                        {
                            <option title="@user.Role" value="@user.UserId">
                                @(user.LName + ", " + user.FName)
                            </option>
                        }
                    }

                    @if ((Model.SearchResults.Count > 0) && (Model.PendingUsersProfiles.Count > 0))
                    {
                        <option value=""></option>
                    }

                    @if (Model.PendingUsersProfiles.Count > 0)
                    {
                        <option value="">Pending Users...</option>

                        @foreach (var user in Model.PendingUsersProfiles)
                        {
                            <option title="Pending" value="@user.EmployeeId">
                                @(user.LName + ", " + user.FName)
                            </option>
                        }
                    }
                </select>
            </div>

            <!-- ROLE SELECTION (Option 1 applied) -->
            <div class="form-group">
                <p>Set Role:</p>

                <div style="display:flex; align-items:center; gap:1.5rem;">

                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="radio" name="TargetRole" value="Clerk" />
                        Clerk
                    </label>

                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="radio" name="TargetRole" value="Employee" />
                        Employee
                    </label>

                </div>
            </div>

            <button type="submit" class="btn-primary" style="margin-top:1rem;">
                Change Role
            </button>

            <!-- VALIDATION SUMMARY -->
            <div asp-validation-summary="All" class="error-text" style="margin-top:1rem;"></div>

        </form>

    </div>

</div>
