@page
@model psts.web.Pages.Manage.ManageCodesModel
@{
    ViewData["Title"] = "Manage - PSTS Solutions";
    ViewData["HideNavbar"] = false;

    var mode = Request.Query["mode"].ToString()?.ToLower() ?? "";
    var isCreate = mode == "create";
    var isUpdate = mode == "update" || Model.FoundType != null;

    // Show right panel whenever a record type is selected or user is creating/updating
    bool showRight = !string.IsNullOrEmpty(Model.RecordTypeSearch) || isCreate || isUpdate;

    string rightHeader = isCreate ? "Create" : isUpdate ? "Update" : "Create or Update";
    string rightButton = isCreate ? "Submit" : isUpdate ? "Update" : "Submit / Update";
}

<h2 style="text-align:center; margin-top:1rem;">Manage Codes</h2>

<div class="profile-grid" style="align-items:stretch;">

    <!-- LEFT PANEL -->
    <div id="profileBox"
         class="profile-box"
         style="display:flex; flex-direction:column; justify-content:center; min-height:18rem;">
        <h2>Lookup Short Code</h2>

        <form method="get">
            <div class="form-group">
                <p>Record Type:</p>
                <select name="recordTypeSearch"
                        required
                        style="width:100%; padding:0.625rem; background-color:var(--primary-bg-color); color:white; border:0.0625rem solid var(--border-bg); border-radius:0.25rem;">
                    <option value="">-- Select --</option>
                    <option value="Client" selected="@(Model.RecordTypeSearch == "Client")">Client</option>
                    <option value="Project" selected="@(Model.RecordTypeSearch == "Project")">Project</option>
                    <option value="Task" selected="@(Model.RecordTypeSearch == "Task")">Task</option>
                </select>

            </div>

            <div class="form-group">
                <p>Enter Short Code:</p>
                <input type="text"
                       name="shortcode"
                       placeholder="Short code..."
                       value="@Model.Shortcode" />
            </div>

            <div style="display:flex; flex-direction:column; gap:0.75rem; width:100%;">
                <button type="submit"
                        class="btn-primary"
                        style="width:100%;"
                        formaction="?recordTypeSearch=@Model.RecordTypeSearch">
                    Submit
                </button>

                <button type="submit"
                        name="mode"
                        value="create"
                        class="btn-primary"
                        style="width:100%;"
                        formaction="?recordTypeSearch=@Model.RecordTypeSearch&mode=create">
                    Create New
                </button>

                <button type="submit"
                        name="mode"
                        value="update"
                        class="btn-primary"
                        style="width:100%;"
                        formaction="?recordTypeSearch=@Model.RecordTypeSearch&mode=update">
                    Update
                </button>

            </div>
        </form>
    </div>

    <!-- RIGHT PANEL -->
    @if (showRight)
    {
        <div id="passwordBox"
             class="password-box"
             style="display:flex; flex-direction:column; justify-content:flex-start; min-height:18rem;">
            <h2>@rightHeader</h2>

            <form method="post" style="flex:1; display:flex; flex-direction:column; justify-content:flex-start;">
                <input type="hidden" name="mode" value="@mode" />
                <input type="hidden" name="recordId" value="@Model.RecordId" />
                <input type="hidden" name="parentId" value="@Model.ParentId" />
                <input type="hidden" name="recordType" value="@Model.RecordTypeSearch" />

                <!-- CLIENT FIELDS -->
                @if (Model.RecordTypeSearch == "Client")
                {
                    <h3>Client</h3>

                    <div class="form-group">
                        <p>Client Name:</p>
                        <input type="text" name="clientName" value="@Model.ClientName" placeholder="Client name..." />
                    </div>

                    <div class="form-group">
                        <p>POC First Name:</p>
                        <input type="text" name="clientPOCfName" value="@Model.ClientPOCfName" placeholder="First name..." />
                    </div>

                    <div class="form-group">
                        <p>POC Last Name:</p>
                        <input type="text" name="clientPOClName" value="@Model.ClientPOClName" placeholder="Last name..." />
                    </div>

                    <div class="form-group">
                        <p>POC Email:</p>
                        <input type="text" name="clientPOCeMail" value="@Model.ClientPOCeMail" placeholder="Email..." />
                    </div>

                    <div class="form-group">
                        <p>POC Phone:</p>
                        <input type="text" name="clientPOCtPhone" value="@Model.ClientPOCtPhone" placeholder="Phone..." />
                    </div>
                }

                <!-- PROJECT FIELDS -->
                @if (Model.RecordTypeSearch == "Project")
                {
                    <h3>Project</h3>

                    @if (isCreate)
                    {
                        <div class="form-group">
                            <p>Parent Client Short Code:</p>
                            <input type="text" name="parentShortCode" value="@Model.ParentShortCode" placeholder="Client short code..." />
                        </div>
                    }

                    <div class="form-group">
                        <p>Project Name:</p>
                        <input type="text" name="projectName" value="@Model.ProjectName" placeholder="Project name..." />
                    </div>

                    <div class="form-group">
                        <p>Project Description:</p>
                        <input type="text" name="projectDescription" value="@Model.ProjectDescription" placeholder="Project description..." />
                    </div>
                }

                <!-- TASK FIELDS -->
                @if (Model.RecordTypeSearch == "Task")
                {
                    <h3>Task</h3>

                    @if (isCreate)
                    {
                        <div class="form-group">
                            <p>Parent Project Short Code:</p>
                            <input type="text" name="parentShortCode" value="@Model.ParentShortCode" placeholder="Project short code..." />
                        </div>
                    }

                    <div class="form-group">
                        <p>Task Name:</p>
                        <input type="text" name="taskName" value="@Model.TaskName" placeholder="Task name..." />
                    </div>

                    <div class="form-group">
                        <p>Task Description:</p>
                        <input type="text" name="taskDescription" value="@Model.TaskDescription" placeholder="Task description..." />
                    </div>
                }

                <button type="submit" class="btn-primary">@rightButton</button>
            </form>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <p class="error-text" style="margin-top:1.5rem; text-align:center;">
        @Model.Message
    </p>
}
