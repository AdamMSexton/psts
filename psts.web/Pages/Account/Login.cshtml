@page
@model Psts.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login - PSTS Solutions";
    ViewData["HideNavbar"] = true;
}

<div id="app-container" class="login-scene">

    <!-- Particle Layer -->
    <canvas id="loginParticles" class="particles-layer"></canvas>

    <!-- Vignette Overlay -->
    <div class="vignette-overlay"></div>

    <!-- Parallax Wrapper -->
    <div class="login-parallax">

        <div class="login-container">

            <!-- WELCOME -->
            <div class="grid-item glass-card welcome-box">
                <div class="welcome-inner">
                    <h1>Greetings, User.</h1>
                    <h2>Please sign in or create an account.</h2>
                </div>
            </div>

            <!-- LOGIN -->
            <div id="login" class="grid-item glass-card">
                <h2>Sign in:</h2>

                <form method="post" id="local-login-form">
                    @Html.AntiForgeryToken()

                    <!-- Floating Input: Username -->
                    <div class="form-group floating-group" data-tooltip="Use your PSTS username.">
                        <input id="UserName"
                               name="UserName"
                               type="text"
                               placeholder=" "
                               autocomplete="username"
                               required
                               class="floating-input" />
                        <label for="UserName">Username...</label>
                        <span class="input-underline"></span>
                    </div>

                    <!-- Floating Input: Password -->
                    <div class="form-group floating-group" data-tooltip="Your password is case-sensitive.">
                        <input id="Password"
                               name="Password"
                               type="password"
                               placeholder=" "
                               autocomplete="current-password"
                               required
                               class="floating-input" />
                        <label for="Password">Password...</label>
                        <span class="input-underline"></span>
                    </div>

                 

                    <!-- Login Button -->
                    <button type="submit" id="local-login-submit" class="btn-primary glass-btn">
                        Login
                    </button>

                    <!-- Links -->
                    <div class="action-row">
                        
                        <br />
                        <br />
                        <br />
                        <br />
                        <br />
                     
                        <a asp-page="./NewUser" class="btn-secondary glass-btn-secondary">Create an account</a>
                    </div>
                </form>

                @if (Model.LoginFailed)
                {
                    <p class="error-text">Login failed</p>
                }
            </div>

            <!-- EXTERNAL LOGIN -->
            @if (Model.OIDCEnabled)
            {
                <div id="loginExternal" class="grid-item glass-card">
                    <h3>Sign in with:</h3>

                    @if (Model.ExternalLogins?.Count > 0)
                    {
                        <form method="post" asp-page-handler="ExternalLogin">
                            @Html.AntiForgeryToken()

                            <div class="external-grid">
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    var backgroundColor = provider.Name switch
                                    {
                                                        "Google" => "google",
                                                        "Microsoft" => "microsoft",
                                                        "Auth0" => "auth0",
                                                        "Okta" => "okta",
                                        _ => "default"
                                    };

                                    var logoPath = Url.Content($"~/Images/ExternalLoginLogos/{provider.Name}.png");

                                    <button type="submit"
                                            name="provider"
                                            value="@provider.Name"
                                            class="external-btn glass-card @backgroundColor">
                                        <div class="external-btn-top">Sign in with:</div>
                                        <div class="external-btn-bottom">
                                            <span class="provider-name">@provider.Name</span>
                                            <img src="@logoPath" alt="@provider.Name logo" class="provider-logo" />
                                        </div>
                                    </button>
                                }
                            </div>
                        </form>

                        @if (!string.IsNullOrEmpty(Model.LoginErrorText))
                        {
                            <p class="error-text">@Model.LoginErrorText</p>
                        }
                    }
                </div>
            }

            <!-- COMPANY CONTENT -->
            <div id="companyContent" class="grid-item glass-card">
                <div class="logo-glow">
                    <h2>PSTS SOLUTIONS</h2>
                    <p>Providing the best solutions for consulting firms, including hour tracking and report generation.</p>

                    <img src="@Url.Content("~/Images/BCO.eb2e4f5c-29cf-4e37-9a8c-8dd773714c58.png")"
                         alt="PSTS Solutions Logo"
                         title="PSTS Solutions Logo"
                         class="company-logo" />
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Login.js" asp-append-version="true"></script>
}
