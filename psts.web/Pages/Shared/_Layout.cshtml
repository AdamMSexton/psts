@{
    // hide if ViewData["HideNavbar"] == true OR if page defines @section HideNavbar {}
    var hideNavbar = false;
    if (ViewData["HideNavbar"] is bool vb && vb) { hideNavbar = true; }
    if (IsSectionDefined("HideNavbar")) { hideNavbar = true; }

@functions {
    bool IsActive(string page)
    {
        var current = ViewContext.ActionDescriptor.RouteValues["page"];
        return string.Equals(current, page, StringComparison.OrdinalIgnoreCase);
    }
}


}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@(ViewData["Title"] ?? "PSTS Solutions")</title>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    @if (!hideNavbar)
    {
        <header>
            <nav class="navBar">
                <ul>

                    <!-- Home -->
                    <li>
                        <a asp-page="/Account/Home"
                           class="icon-button @(IsActive("/Account/Home") ? "active-link" : "")">
                            <img src="~/Images/navBarIcons/home.svg" alt="Home" />
                        </a>
                    </li>

                    @if (User.IsInRole("Employee"))
                    {
                        <li>
                            <a asp-page="/Hours/Hours"
                               class="@(IsActive("/Hours/Hours") ? "active-link" : "")">
                                Hours
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Manager"))
                    {
                        <li class="has-dropdown">
                            <a>
                                Hours
                            </a>
                            <ul class="dropdown">
                                <li>
                                    <a asp-page="/Hours/Hours"
                                       class="@(IsActive("/Hours/Hours") ? "active-link" : "")">
                                        Add
                                    </a>
                                </li>
                                <li>
                                    <a asp-page="/Manage/changeBillingRate"
                                       class="@(IsActive("/Manage/changeBillingRate") ? "active-link" : "")">
                                        Rates
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }

                    @if (User.IsInRole("Clerk") || User.IsInRole("Manager") || User.IsInRole("Employee"))
                    {
                        <li>
                            <a asp-page="/Reports/Index"
                               class="@(IsActive("/Reports/Index") ? "active-link" : "")">
                                Reports
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Manager"))
                    {
                        <li class="has-dropdown">
                            <a>
                                Manage
                            </a>
                            <ul class="dropdown">
                                <li>
                                    <a asp-page="/Manage/ManageCodes"
                                       class="@(IsActive("/Manage/ManageCodes") ? "active-link" : "")">
                                        Codes
                                    </a>
                                </li>
                                <li>
                                    <a asp-page="/Manage/manageRoles"
                                       class="@(IsActive("/Manage/manageRoles") ? "active-link" : "")">
                                        Roles
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a asp-page="/Admin/AdminUserTool"
                               class="@(IsActive("/Admin/AdminUserTool") ? "active-link" : "")">
                                Tools
                            </a>
                        </li>
                        <li>
                            <a asp-page="/appSettings/appSettings"
                               class="@(IsActive("/appSettings/appSettings") ? "active-link" : "")">
                                App Settings
                            </a>
                        </li>
                    }

                    <li>
                        <a asp-page="/Account/Profile"
                           class="@(IsActive("/Account/Profile") ? "active-link" : "")">
                            Profile
                        </a>
                    </li>

                    <!-- Logout -->
                    <li>
                        <form method="post" asp-page="/Account/Logout" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="icon-button @(IsActive("/Account/Logout") ? "active-link" : "")">
                                <img src="~/Images/navBarIcons/log-out.svg" alt="Logout" />
                            </button>
                        </form>
                    </li>


                </ul>

            </nav>
        </header>
    }

    <main>
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>
