@page
@model psts.web.Pages.Admin.AdminUserToolsModel
@{
    ViewData["Title"] = "Admin User Tool - PSTS Solutions";
}

<script src="~/js/UserSearch.js"></script>
<script>    
    document.addEventListener('DOMContentLoaded', function() 
    {
        InitalizeUserSearch("userQuery","searchResults","/Admin/AdminUserTools?handler=Search");
    });
</script>


<h2 style="text-align:center; margin-top:1rem;">Admin User Tool</h2>


<div class="profile-grid">

    <!-- -------------------------------------------------- -->
    <!-- SEARCH BOX -->
    <!-- -------------------------------------------------- -->
    <div class="profile-box grid-item">
        <h2>Find User</h2>
        <div class="form-group">
            <p>Search by Name:</p>
            <input type="text"
                    id="userQuery"
                    value="@Model.Query"
                    placeholder="First and/or last name..." />
        </div>
        <br /><br />
        <!-- VALIDATION SUMMARY -->
        <div asp-validation-summary="All" class="error-text" style="margin-top:1rem;"></div>
    </div>


    <!-- -------------------------------------------------- -->
    <!-- ROLE MANAGEMENT BOX -->
    <!-- -------------------------------------------------- -->
    <form method="post">
        <div class="password-box grid-item">

            <h2>Assign Role</h2>

            <!-- USER LIST -->
            <div class="form-group">
                <p>Select User:</p>

                <select name="SelectedUserId"
                        id="SelectedUserId"
                        size="8"
                        style="width:100%; padding:0.625rem; background-color:var(--primary-bg-color); color:white; border:0.0625rem solid var(--border-bg); border-radius:0.25rem;">

                    <optgroup label="Search Results" id="searchResults">
                        
                    </optgroup>
                </select>
            </div>

            <!-- ROLE SELECTION (Option 1 applied) -->
            <div class="form-group">
                <p>Set Role:</p>

                <div style="display:flex; align-items:center; gap:1.5rem;">

                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="radio" name="TargetRole" value="Clerk" />
                        Clerk
                    </label>

                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="radio" name="TargetRole" value="Employee" />
                        Employee
                    </label>

                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="radio" name="TargetRole" value="Manager" />
                        Manager
                    </label>

                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="radio" name="TargetRole" value="Admin" />
                        Admin
                    </label>
                </div>
            </div>
        </div>
    </form>

        <div class="settings-box grid-item">
            <h2>User Settings</h2>
            <div class="form-group">
                <div style="display:flex; flex-direction:column; align-items:flex-start; gap:0.5rem;">
                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="checkbox" name="LoginPassAllowed" value="true" />
                        Allow login & password
                    </label>
                    <br />
                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="checkbox" name="OIDCAllowed" value="false" />
                        Allow OIDC login
                    </label>
                    <br />
                    <label style="display:flex; align-items:center; gap:0.5rem; margin:0;">
                        <input type="checkbox" name="ResetPassOnLogin" value="false" />
                        Force password reset on next login
                    </label>
                    <br />
                    <button type="submit" class="btn-primary" style="margin-top:1rem;">
                        Change Role
                    </button>
                </div>
            </div>
        </div>
</div>
